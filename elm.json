{
    "type": "package",
    "name": "jxxcarlson/xmarkdown-compiler",
    "summary": "A compiler for XMarkdown (Scientific Markdown)",
    "license": "MIT",
    "version": "1.0.0",
    "exposed-modules": [
        "XMarkdown.API",
        "XMarkdown.Types",
        "XMarkdown.Msg",
        "Render.Theme",
        "XMarkdown.Editor",
        "XMarkdown.Sync"
    ],
    "elm-version": "0.19.0 <= v < 0.20.0",
    "dependencies": {
        "avh4/elm-color": "1.0.0 <= v < 2.0.0",
        "elm/core": "1.0.0 <= v < 2.0.0",
        "elm/html": "1.0.0 <= v < 2.0.0",
        "elm/json": "1.1.3 <= v < 2.0.0",
        "elm/parser": "1.1.0 <= v < 2.0.0",
        "elm/regex": "1.0.0 <= v < 2.0.0",
        "elmcraft/core-extra": "2.0.0 <= v < 3.0.0",
        "jxxcarlson/etex": "1.0.0 <= v < 2.0.0",
        "maca/elm-rose-tree": "1.2.1 <= v < 2.0.0",
        "mdgriffith/elm-ui": "1.1.8 <= v < 2.0.0",
        "pablohirafuji/elm-syntax-highlight": "3.5.0 <= v < 4.0.0",
        "toastal/either": "3.6.3 <= v < 4.0.0"
    },
    "test-dependencies": {
        "elm-explorations/test": "2.0.0 <= v < 3.0.0"
    }
}
